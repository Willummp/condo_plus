{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Visao geral dos microsservicos do Condo+: disponibilidade, latencia, erros, JVM e Kafka.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Disponibilidade",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "1 = servico UP, 0 = DOWN (do ponto de vista do Prometheus).",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "red", "text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"color": "green", "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "green", "value": 1}]}
        }
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "up{tier=\"application\"}",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Status dos servicos",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7},
      "id": 101,
      "panels": [],
      "title": "HTTP",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Requisicoes por segundo, agregadas por servico.",
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 2,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{tier=\"application\"}[1m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Throughput HTTP (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Percentil 95 de latencia (segundos).",
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 3,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum by (application, le) (rate(http_server_requests_seconds_bucket{tier=\"application\"}[5m])))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Latencia HTTP p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Fracao de requests com status 5xx.",
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 4,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"5..\",tier=\"application\"}[5m])) / sum by (application) (rate(http_server_requests_seconds_count{tier=\"application\"}[5m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Taxa de erro 5xx",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 102,
      "panels": [],
      "title": "JVM",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Uso de heap por servico (fracao do maximo).",
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "unit": "percentunit",
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.85}]}
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\",tier=\"application\"}) / sum by (application) (jvm_memory_max_bytes{area=\"heap\",tier=\"application\"})",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Uso de heap (%)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Threads live da JVM (inclui threads daemon e user).",
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (application) (jvm_threads_live_threads{tier=\"application\"})",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Threads JVM",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33},
      "id": 103,
      "panels": [],
      "title": "Kafka",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Records atrasados por consumer/topico. Ideal e ficar proximo de zero.",
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 100}, {"color": "red", "value": 1000}]}
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 34},
      "id": 7,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (application, topic) (kafka_consumer_fetch_manager_records_lag)",
          "legendFormat": "{{application}} - {{topic}}",
          "refId": "A"
        }
      ],
      "title": "Consumer lag Kafka",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["condoplus", "overview"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Condo+ - Visao Geral",
  "uid": "condoplus-overview",
  "version": 1,
  "weekStart": ""
